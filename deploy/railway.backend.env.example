# Railway backend service variables
# Service names must match these internal host names:
# mariadb, mongodb, redis, kafka

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
PORT=8080

JWT_SECRET_KEY=replace_with_openssl_rand_hex_64
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14

DB_URL=jdbc:mariadb://mariadb.railway.internal:3306/finvibe
DB_USERNAME=finvibe
DB_PASSWORD=replace_with_mariadb_password

REDIS_HOST=redis.railway.internal
REDIS_PORT=6379

MONGODB_URI=mongodb://root:replace_with_mongodb_password@mongodb.railway.internal:27017/finvibe?authSource=admin
SPRING_MONGODB_URI=mongodb://root:replace_with_mongodb_password@mongodb.railway.internal:27017/finvibe?authSource=admin
SPRING_DATA_MONGODB_URI=mongodb://root:replace_with_mongodb_password@mongodb.railway.internal:27017/finvibe?authSource=admin

KAFKA_BOOTSTRAP_SERVERS=kafka.railway.internal:9092

FINVIBE_DATA_DIR=/app/runtime

# First deploy: use the Vercel URL.
# Final custom domain example:
# CORS_ALLOWED_ORIGINS=https://finvibe.kr,https://www.finvibe.kr
CORS_ALLOWED_ORIGINS=https://replace-with-your-front.vercel.app

# First deploy should keep external APIs off until the app boots cleanly.
KIS_ENABLED=false
KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_TIMEOUT_MS=5000

NAVER_NEWS_ENABLED=false
NAVER_NEWS_BASE_URL=https://openapi.naver.com/v1/search/news.json
NAVER_NEWS_CLIENT_ID=
NAVER_NEWS_CLIENT_SECRET=
NAVER_NEWS_TIMEOUT_MS=7000

OPENROUTER_ENABLED=false
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_TIMEOUT_MS=20000
OPENROUTER_SITE_URL=https://replace-with-your-front.vercel.app

FINVIBE_MARKET_BOOTSTRAP_PRICES_ENABLED=true
FINVIBE_MARKET_BOOTSTRAP_PRICES_RUN_ON_STARTUP=false
FINVIBE_MARKET_BOOTSTRAP_PRICES_SCHEDULE_ENABLED=true
FINVIBE_MARKET_BOOTSTRAP_PRICES_PAGE_SIZE=50
FINVIBE_MARKET_BOOTSTRAP_PRICES_MAX_PAGES_PER_RUN=4
FINVIBE_MARKET_BOOTSTRAP_PRICES_REQUEST_DELAY_MS=150
FINVIBE_MARKET_BOOTSTRAP_PRICES_REFRESH_ZERO_ONLY=true
FINVIBE_MARKET_BOOTSTRAP_PRICES_STALE_AFTER_MINUTES=180
FINVIBE_MARKET_BOOTSTRAP_PRICES_CRON=0 0/10 * * * *
FINVIBE_MARKET_BOOTSTRAP_PRICES_STARTUP_DELAY_MS=10000

FINVIBE_MARKET_CANDLE_BACKFILL_ENABLED=true
FINVIBE_MARKET_CANDLE_BACKFILL_RUN_ON_STARTUP=false
FINVIBE_MARKET_CANDLE_BACKFILL_SCHEDULE_ENABLED=true
FINVIBE_MARKET_CANDLE_BACKFILL_PAGE_SIZE=50
FINVIBE_MARKET_CANDLE_BACKFILL_MAX_PAGES_PER_RUN=4
FINVIBE_MARKET_CANDLE_BACKFILL_POINTS=60
FINVIBE_MARKET_CANDLE_BACKFILL_MINIMUM_POINTS=20
FINVIBE_MARKET_CANDLE_BACKFILL_REQUEST_DELAY_MS=300
FINVIBE_MARKET_CANDLE_BACKFILL_CRON=0 3/5 * * * *
FINVIBE_MARKET_CANDLE_BACKFILL_STARTUP_DELAY_MS=20000

FINVIBE_TRADE_PENDING_ORDERS_ENABLED=true
FINVIBE_TRADE_PENDING_ORDERS_POLL_DELAY_MS=5000
FINVIBE_TRADE_PENDING_ORDERS_MAX_PER_RUN=100
